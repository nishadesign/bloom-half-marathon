generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  Int       @id @default(autoincrement())
  name                String
  ageYears            Int
  sex                 String
  heightCm            Float
  weightKg            Float
  diet                String
  raceDate            DateTime
  goalTimeMinutes     Int
  currentWeeklyKm     Float
  longestRecentRunKm  Float
  crossfitDays        String
  runDays             String
  stravaAthleteId     String?
  stravaAccessToken   String?
  stravaRefreshToken  String?
  stravaTokenExpires  Int?
  lastSyncedAt        DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  activities          Activity[]
  plans               Plan[]
  mealLogs            MealLog[]
}

model Activity {
  id             Int      @id @default(autoincrement())
  stravaId       String   @unique
  userId         Int
  user           User     @relation(fields: [userId], references: [id])
  type           String
  sportType      String
  name           String
  startDate      DateTime
  distanceMeters Float
  movingSeconds  Int
  elapsedSeconds Int
  elevationGain  Float
  avgHeartrate   Float?
  maxHeartrate   Float?
  avgSpeed       Float?
  calories       Float?
  createdAt      DateTime @default(now())
}

model Plan {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         User     @relation(fields: [userId], references: [id])
  weekStart    DateTime
  weekNumber   Int
  contentJson  String
  createdAt    DateTime @default(now())

  @@unique([userId, weekStart])
}

model Meal {
  id                  Int       @id @default(autoincrement())
  name                String    @unique
  mealType            String
  portionDescription  String
  calories            Int
  proteinGrams        Float
  carbsGrams          Float
  fatGrams            Float
  fiberGrams          Float?
  notes               String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  logs                MealLog[]
}

model MealLog {
  id         Int       @id @default(autoincrement())
  userId     Int
  user       User      @relation(fields: [userId], references: [id])
  mealId     Int
  meal       Meal      @relation(fields: [mealId], references: [id])
  date       DateTime
  mealType   String
  portions   Float     @default(1)
  createdAt  DateTime  @default(now())
}
